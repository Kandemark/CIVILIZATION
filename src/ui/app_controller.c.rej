--- src/ui/app_controller.c
+++ src/ui/app_controller.c
@@ -129,6 +129,7 @@ void civ_app_controller_run(civ_app_controller_t *app) {
     civ_window_clear(app->window, CIV_COLOR_BG_DARK);
 
     /* Nuklear begin */
+    static int fc = 0; if (fc < 3) { fprintf(stderr, "[APP] frame %d: begin\n", fc); }
     nk_ui_begin();
 
     civ_scene_manager_render(civ_window_get_renderer(app->window), win_w, win_h,
@@ -136,6 +137,7 @@ void civ_app_controller_run(civ_app_controller_t *app) {
     civ_window_mgr_render(&app->window_mgr, civ_window_get_renderer(app->window), NULL);
 
     /* Nuklear end */
+    if (fc < 3) { fprintf(stderr, "[APP] frame %d: end\n", fc); fc++; }
     nk_ui_end();
 
 
